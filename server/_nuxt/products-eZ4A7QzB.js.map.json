AAAA,QACP,UAAU;AAAA,QACV,MAAM;AAAA,QACN,OAAO;AAAA,QACP,aAAa;AAAA,QACb,OAAO;AAAA,UACL,OAAO;AAAA,UACP,MAAM;AAAA,UACN,MAAM;AAAA,UACN,SAAS;AAAA,QACf;AAAA,MACA;AAAA,IACA;AAEA,UAAM,oBAAoB,SAAS,MAAM;AACvC,aAAO,gBAAgB,YAAY,KAAK,KAAK,CAAA;AAAA,IAC/C,CAAC;AAOD,UAAM,mBAAmB,CAAC,QAAQ;AAChC,YAAM,cAAc,gBAAgB,YAAY,KAAK,KAAK,CAAA;AAC1D,YAAM,UAAU,YAAY,KAAK,OAAK,EAAE,UAAU,GAAG;AACrD,aAAO,UAAU,QAAQ,QAAQ;AAAA,IACnC;AAEA,UAAM,wBAAwB,CAAC,YAAY;AACzC,YAAM,cAAc,gBAAgB,QAAQ,KAAK,KAAK,CAAA;AACtD,YAAM,UAAU,YAAY,KAAK,OAAK,EAAE,UAAU,QAAQ,QAAQ;AAClE,aAAO,UAAU,QAAQ,MAAM;AAAA,IACjC;AAEA,UAAM,mBAAmB,SAAS,MAAM;AACtC,aAAO,SAAS,OAAO,OAAK;AAC1B,cAAM,eAAe,EAAE,UAAU,YAAY;AAC7C,cAAM,kBAAkB,eAAe,UAAU,SAAS,EAAE,aAAa,eAAe;AACxF,cAAM,gBACJ,EAAE,KAAK,YAAW,EAAG,SAAS,YAAY,MAAM,aAAa,KAC7D,EAAE,MAAM,YAAW,EAAG,SAAS,YAAY,MAAM,aAAa,KAC9D,EAAE,YAAY,YAAW,EAAG,SAAS,YAAY,MAAM,YAAW,CAAE;AACtE,eAAO,gBAAgB,mBAAmB;AAAA,MAC5C,CAAC;AAAA,IACH,CAAC;;;;AAzYyBA,oBAAA,SAAT,UAAK;;UAIU,YAAA,UAAgB,MAAM;sFAMzCC,eAAA,MAAM,KAAK;;;AAUID,oBAAA,kBAAA,QAAP,QAAG;;UAIgB,eAAA,UAAmB,IAAI;0FAM9CC,eAAA,IAAI,KAAK;;;;QAMd,IAAG;AAAA,QACH,OAAM;AAAA;yBAFR,CAKW,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAFV,aAED;AAAA;;;;;;AAUY,YAAAC,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;kDAGd,YAAA,KAAW,CAAA,wVAAA;AAUjB,UAAA,iBAAA,MAAiB,SAAM,GAAA;;AAEZL,sBAAA,iBAAA,QAAX,YAAO;AAWkE,gBAAA,y5BAAAC,eAAA,QAAQ,KAAK,CAAA,SAAA;AAClF,gBAAAG,mBAAAC,MAAA,GAAA,GAAA,EAAA,OAAM,qBAAoB,GAAA,MAAA,OAAA,CAAA;gQAO1BJ,eAAA,QAAQ,KAAK,omBAkBb,iBAAiB,QAAQ,QAAQ,CAAA,4EAGjCA,eAAA,QAAQ,KAAK,8EAG4CA,eAAA,QAAQ,IAAI,yFACOA,eAAA,QAAQ,KAAK,8EACvBA,eAAA,QAAQ,WAAW;AAKzDD,wBAAA,QAAQ,OAAK,CAAnC,SAAS,aAAQ;2GACI,QAAQ,yFAC0B,OAAO;;;AAOnE,cAAA,sBAAsB,OAAO,GAAA;qCAClC,QAAM,sBAAsB,OAAO,CAAA,CAAA,kSAAA;AAAA;;;;YAQnC,IAAE,EAAA,MAAA,YAAA,OAAA,EAAA,OAAsC,QAAQ,QAAK;AAAA,YACtD,OAAM;AAAA;6BAFR,CAKW,GAAAE,QAAAC,UAAA,aAAA;;;;;kCAFV,cAED;AAAA;;;;;;;;;;AAQD,cAAAC,mBAAAC,MAAA,GAAA,GAAA,EAAA,OAAM,uDAAsD,GAAA,MAAA,OAAA,CAAA;;;;;;;;;;;;;","names":["_ssrRenderList","_ssrInterpolate","_push","_parent","_ssrRenderComponent","_unref"],"sources":["../../../../pages/products.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- Subpage Banner -->\n    <section class=\"bg-gradient-to-r from-slate-900 via-slate-950 to-primary-950 text-white py-16 md:py-24 text-center relative\">\n      <div class=\"absolute inset-0 bg-slate-950/20 backdrop-blur-[1px]\"></div>\n      <div class=\"relative max-w-4xl mx-auto px-4 space-y-4\">\n        <h1 class=\"text-3xl sm:text-4xl font-extrabold tracking-tight\">제품 소개</h1>\n        <p class=\"text-slate-300 text-sm sm:text-base max-w-lg mx-auto\">\n          글로벌 파트너사의 최상급 부품 라인업을 신속하고 투명하게 견적 및 납품해 드립니다.\n        </p>\n      </div>\n    </section>\n\n    <!-- Catalog Section -->\n    <section class=\"py-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n      <!-- Top-Level Brand Tabs -->\n      <div class=\"border-b border-slate-200 dark:border-slate-800 mb-8 flex flex-wrap gap-1\">\n        <button\n          v-for=\"brand in brands\"\n          :key=\"brand.value\"\n          @click=\"selectBrand(brand.value)\"\n          class=\"px-6 py-3 border-b-2 text-sm sm:text-base font-bold transition-all\"\n          :class=\"[\n            activeBrand === brand.value\n              ? 'border-primary-600 text-primary-600 dark:border-primary-400 dark:text-primary-400'\n              : 'border-transparent text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200'\n          ]\"\n        >\n          {{ brand.label }}\n        </button>\n      </div>\n\n      <!-- Search and Filter Bar -->\n      <div class=\"space-y-6 mb-12\">\n        <!-- Sub-Category Filters and Inquiry CTA -->\n        <div class=\"flex flex-col lg:flex-row lg:items-center justify-between gap-4\">\n          <div class=\"flex flex-wrap gap-2 max-w-4xl\">\n            <button\n              v-for=\"cat in currentCategories\"\n              :key=\"cat.value\"\n              @click=\"activeCategory = cat.value\"\n              class=\"px-4 py-2.5 rounded-xl text-xs sm:text-sm font-semibold transition-all\"\n              :class=\"[\n                activeCategory === cat.value\n                  ? 'bg-primary-600 text-white shadow-md shadow-primary-500/15'\n                  : 'bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 border border-slate-200/60 dark:border-slate-800/80 hover:bg-slate-50 dark:hover:bg-slate-800/50'\n              ]\"\n            >\n              {{ cat.label }}\n            </button>\n          </div>\n          \n          <!-- Inquiry Button link -->\n          <NuxtLink \n            to=\"/inquiry\"\n            class=\"px-6 py-3 bg-sky-600 hover:bg-sky-500 text-white rounded-xl text-sm font-bold shadow-md shadow-sky-500/10 transition-all hover:scale-105 shrink-0 text-center\"\n          >\n            견적 및 문의하기\n          </NuxtLink>\n        </div>\n\n        <!-- Search input & external link helper text -->\n        <div class=\"flex flex-col sm:flex-row items-center justify-between gap-4 pt-4 border-t border-slate-100 dark:border-slate-800\">\n          <p class=\"text-xs text-slate-500 dark:text-slate-400\">\n            * 각 하위 카테고리를 클릭하면 대표 취급 기기 스펙 필터링 및 제조사 공식 상세 사이트 링크가 제공됩니다.\n          </p>\n          <div class=\"relative max-w-xs w-full\">\n            <div class=\"absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400\">\n              <Search class=\"w-4 h-4\" />\n            </div>\n            <input\n              v-model=\"searchQuery\"\n              type=\"text\"\n              placeholder=\"모델명 또는 스펙 검색...\"\n              class=\"w-full pl-10 pr-4 py-2 text-sm bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-xl text-slate-800 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <!-- Results Grid -->\n      <div v-if=\"filteredProducts.length > 0\" class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8\">\n        <div \n          v-for=\"product in filteredProducts\" \n          :key=\"product.id\"\n          class=\"bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between\"\n        >\n          <!-- Product Visual Representation -->\n          <div class=\"bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-950 dark:to-slate-900 h-52 flex items-center justify-center p-6 relative overflow-hidden\">\n            <div class=\"absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] dark:bg-[radial-gradient(#1e293b_1px,transparent_1px)] [background-size:16px_16px] opacity-70\"></div>\n            \n            <!-- Graphic Mockup -->\n            <div class=\"relative w-28 h-36 bg-primary-600 dark:bg-primary-700 text-white rounded-xl shadow-lg border-2 border-white/20 flex flex-col justify-between p-3.5 select-none transform hover:scale-105 transition-transform duration-300\">\n              <div class=\"flex justify-between items-start\">\n                <span class=\"text-[9px] font-bold tracking-wider opacity-85 uppercase\">{{ product.brand }}</span>\n                <Cpu class=\"w-4 h-4 opacity-75\" />\n              </div>\n              \n              <div class=\"space-y-1.5 my-auto\">\n                <div class=\"h-0.5 bg-white/30 rounded w-full\"></div>\n                <div class=\"h-0.5 bg-white/20 rounded w-2/3\"></div>\n                <p class=\"text-[9px] font-mono text-center tracking-tight text-primary-200 font-bold truncate\">\n                  {{ product.model }}\n                </p>\n              </div>\n\n              <div class=\"flex justify-around items-end\">\n                <div class=\"w-1 h-2 bg-slate-300 dark:bg-slate-400 rounded-t-sm\"></div>\n                <div class=\"w-1 h-2 bg-slate-300 dark:bg-slate-400 rounded-t-sm\"></div>\n                <div class=\"w-1 h-2 bg-slate-300 dark:bg-slate-400 rounded-t-sm\"></div>\n                <div class=\"w-1 h-2 bg-slate-300 dark:bg-slate-400 rounded-t-sm\"></div>\n              </div>\n            </div>\n          </div>\n\n          <!-- Product Details -->\n          <div class=\"p-6 flex-grow flex flex-col justify-between space-y-6\">\n            <div class=\"space-y-2\">\n              <div class=\"flex justify-between items-center\">\n                <span class=\"text-[10px] font-bold uppercase tracking-widest text-primary-600 dark:text-primary-400\">\n                  {{ getCategoryLabel(product.category) }}\n                </span>\n                <span class=\"text-[10px] font-semibold text-slate-400 uppercase\">\n                  {{ product.brand }}\n                </span>\n              </div>\n              <h3 class=\"text-lg font-bold text-slate-900 dark:text-white\">{{ product.name }}</h3>\n              <p class=\"text-xs text-slate-500 dark:text-slate-400 font-mono leading-relaxed\">{{ product.model }}</p>\n              <p class=\"text-sm text-slate-600 dark:text-slate-300 leading-relaxed\">{{ product.description }}</p>\n            </div>\n\n            <!-- Specifications Table -->\n            <div class=\"border-t border-slate-100 dark:border-slate-800/80 pt-4 space-y-2\">\n              <div v-for=\"(specVal, specName) in product.specs\" :key=\"specName\" class=\"flex justify-between text-xs\">\n                <span class=\"text-slate-400\">{{ specName }}</span>\n                <span class=\"font-semibold text-slate-700 dark:text-slate-200\">{{ specVal }}</span>\n              </div>\n            </div>\n\n            <!-- Actions -->\n            <div class=\"pt-4 border-t border-slate-100 dark:border-slate-800/80 space-y-2\">\n              <a \n                v-if=\"getProductExternalUrl(product)\" \n                :href=\"getProductExternalUrl(product)\" \n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                class=\"block w-full text-center py-2.5 text-xs font-semibold text-primary-600 dark:text-primary-400 border border-primary-500/20 hover:border-primary-500/40 bg-primary-500/5 dark:bg-primary-500/10 rounded-xl transition-all\"\n              >\n                제조사 공식 제품 페이지 ↗\n              </a>\n              <NuxtLink \n                :to=\"{ path: '/inquiry', query: { model: product.model } }\" \n                class=\"block w-full text-center py-2.5 text-xs font-semibold text-white bg-slate-800 hover:bg-slate-700 dark:bg-slate-850 dark:hover:bg-slate-800 rounded-xl transition-all\"\n              >\n                견적 및 사양 문의\n              </NuxtLink>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- No Results -->\n      <div v-else class=\"text-center py-24 space-y-4\">\n        <Cpu class=\"w-12 h-12 text-slate-300 dark:text-slate-700 mx-auto\" />\n        <p class=\"text-base font-semibold text-slate-600 dark:text-slate-400\">검색 조건에 맞는 제품이 없습니다.</p>\n        <button \n          @click=\"resetFilters\" \n          class=\"text-xs font-bold text-primary-600 dark:text-primary-400 hover:underline\"\n        >\n          필터 초기화\n        </button>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\nimport { Search, Cpu } from 'lucide-vue-next'\n\nconst searchQuery = ref('')\nconst activeBrand = ref('omron')\nconst activeCategory = ref('all')\n\nconst brands = [\n  { label: 'OMRON (오므론)', value: 'omron' },\n  { label: '신화옵트론', value: 'shinhwa' },\n  { label: 'HR (한국릴레이)', value: 'hr' },\n  { label: 'OTAX (오탁스)', value: 'otax' },\n  { label: 'KACON (카콘)', value: 'kacon' }\n]\n\nconst brandCategories = {\n  omron: [\n    { label: '전체 OMRON 제품', value: 'all' },\n    { label: '센서', value: '01', url: 'https://www.ia.omron.co.kr/products/products?category=01' },\n    { label: '컨트롤러', value: '05', url: 'https: