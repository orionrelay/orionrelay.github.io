w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n      <div class=\"flex items-center justify-between h-20\">\n        <!-- Logo -->\n        <NuxtLink to=\"/\" class=\"flex items-center gap-3.5 group\">\n          <!-- Vector Orion Orbit Emblem -->\n          <div class=\"text-primary-600 dark:text-primary-400 transition-transform duration-300 group-hover:scale-105\">\n            <svg class=\"w-10 h-10 md:w-11 md:h-11\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <!-- Outer orbit ring -->\n              <circle cx=\"50\" cy=\"50\" r=\"40\" stroke=\"currentColor\" stroke-width=\"4\" stroke-dasharray=\"8 6\" class=\"opacity-40\" />\n              <!-- Diagonal orbits -->\n              <ellipse cx=\"50\" cy=\"50\" rx=\"43\" ry=\"13\" stroke=\"currentColor\" stroke-width=\"4\" transform=\"rotate(-30 50 50)\" />\n              <ellipse cx=\"50\" cy=\"50\" rx=\"43\" ry=\"13\" stroke=\"currentColor\" stroke-width=\"4\" transform=\"rotate(30 50 50)\" />\n              <!-- Center glowing star representing Orion -->\n              <path d=\"M50 25L53.5 42.5L71 46L53.5 49.5L50 67L46.5 49.5L29 46L46.5 42.5Z\" fill=\"currentColor\" />\n            </svg>\n          </div>\n          <!-- Corporate Typography -->\n          <div class=\"flex flex-col\">\n            <span class=\"text-xl md:text-2xl font-black tracking-tight text-slate-900 dark:text-white transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400 leading-none\">\n              오리온기전\n            </span>\n            <span class=\"text-[10px] md:text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mt-1.5\">\n              ORION RELAY\n            </span>\n          </div>\n        </NuxtLink>\n\n        <!-- Desktop Navigation -->\n        <nav class=\"hidden md:flex items-center gap-8\">\n          <NuxtLink \n            v-for=\"item in navItems\" \n            :key=\"item.path\" \n            :to=\"item.path\"\n            class=\"text-base font-semibold text-slate-700 dark:text-slate-200 hover:text-primary-600 dark:hover:text-primary-400 transition-all py-2 border-b-2\"\n            :class=\"[route.path === item.path ? 'border-primary-600 dark:border-primary-400 text-primary-600 dark:text-primary-400' : 'border-transparent']\"\n          >\n            {{ item.name }}\n          </NuxtLink>\n        </nav>\n\n        <!-- Action / Utilities -->\n        <div class=\"hidden md:flex items-center gap-4\">\n          <!-- Theme Toggle -->\n          <button \n            @click=\"toggleTheme\" \n            class=\"p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all hover:scale-105\"\n            aria-label=\"Toggle Theme\"\n          >\n            <Sun v-if=\"colorMode.value === 'dark'\" class=\"w-5 h-5 text-amber-500\" />\n            <Moon v-else class=\"w-5 h-5 text-slate-700 dark:text-slate-200\" />\n          </button>\n\n          <!-- Quote CTA -->\n          <NuxtLink \n            to=\"/inquiry\" \n            class=\"px-5 py-2.5 text-sm font-semibold text-white bg-primary-600 hover:bg-primary-500 rounded-xl transition-all hover:scale-105 shadow-md shadow-primary-500/10 hover:shadow-primary-500/20\"\n          >\n            견적 및 문의\n          </NuxtLink>\n        </div>\n\n        <!-- Mobile Menu Buttons -->\n        <div class=\"flex items-center gap-2 md:hidden\">\n          <button \n            @click=\"toggleTheme\" \n            class=\"p-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all\"\n          >\n            <Sun v-if=\"colorMode.value === 'dark'\" class=\"w-5 h-5 text-amber-500\" />\n            <Moon v-else class=\"w-5 h-5 text-slate-700 dark:text-slate-200\" />\n          </button>\n          \n          <button \n            @click=\"isMobileMenuOpen = !isMobileMenuOpen\" \n            class=\"p-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all\"\n          >\n            <X v-if=\"isMobileMenuOpen\" class=\"w-6 h-6\" />\n            <Menu v-else class=\"w-6 h-6\" />\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Mobile Drawer -->\n    <Transition\n      enter-active-class=\"transition duration-200 ease-out\"\n      enter-from-class=\"opacity-0 -translate-y-4\"\n      enter-to-class=\"opacity-100 translate-y-0\"\n      leave-active-class=\"transition duration-150 ease-in\"\n      leave-from-class=\"opacity-100 translate-y-0\"\n      leave-to-class=\"opacity-0 -translate-y-4\"\n    >\n      <div \n        v-if=\"isMobileMenuOpen\" \n        class=\"md:hidden border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 px-4 pt-2 pb-6 space-y-3 shadow-xl\"\n      >\n        <NuxtLink \n          v-for=\"item in navItems\" \n          :key=\"item.path\" \n          :to=\"item.path\"\n          @click=\"isMobileMenuOpen = false\"\n          class=\"block px-4 py-3 rounded-xl text-base font-semibold text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-900 hover:text-primary-600 dark:hover:text-primary-400 transition-all\"\n          :class=\"[route.path === item.path ? 'bg-primary-50 dark:bg-primary-950/30 text-primary-600 dark:text-primary-400' : '']\"\n        >\n          {{ item.name }}\n        </NuxtLink>\n        <div class=\"pt-4 border-t border-slate-100 dark:border-slate-800 px-4\">\n          <NuxtLink \n            to=\"/inquiry\" \n            @click=\"isMobileMenuOpen = false\"\n            class=\"block w-full text-center py-3 px-4 text-sm font-semibold text-white bg-primary-600 hover:bg-primary-500 rounded-xl transition-all shadow-md\"\n          >\n            견적 및 문의\n          </NuxtLink>\n        </div>\n      </div>\n    </Transition>\n  </header>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { useRoute } from 'vue-router'\nimport { Cpu, Sun, Moon, Menu, X } from 'lucide-vue-next'\n\nconst route = useRoute()\nconst colorMode = useColorMode()\nconst isMobileMenuOpen = ref(false)\n\nconst navItems = [\n  { name: '홈', path: '/' },\n  { name: '회사 소개', path: '/company' },\n  { name: '제품 소개', path: '/products' },\n  { name: '온라인 문의', path: '/inquiry' }\n]\n\nconst toggleTheme = () => {\n  colorMode.preference = colorMode.value === 'dark' ? 'light' : 'dark'\n}\n</script>\n","<template>\n  <footer\n    class=\"bg-slate-900 text-slate-300 dark:bg-slate-950 border-t border-slate-800 transition-colors duration-300\"\n  >\n    <!-- Top Footer -->\n    <div\n      class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 grid grid-cols-1 md:grid-cols-4 gap-8\"\n    >\n      <!-- Info Column -->\n      <div class=\"md:col-span-2 space-y-6\">\n        <div class=\"flex items-center gap-3.5\">\n          <!-- Vector Orion Orbit Emblem -->\n          <div class=\"text-white\">\n            <svg class=\"w-10 h-10\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <!-- Outer orbit ring -->\n              <circle cx=\"50\" cy=\"50\" r=\"40\" stroke=\"currentColor\" stroke-width=\"4\" stroke-dasharray=\"8 6\" class=\"opacity-40\" />\n              <!-- Diagonal orbits -->\n              <ellipse cx=\"50\" cy=\"50\" rx=\"43\" ry=\"13\" stroke=\"currentColor\" stroke-width=\"4\" transform=\"rotate(-30 50 50)\" />\n              <ellipse cx=\"50\" cy=\"50\" rx=\"43\" ry=\"13\" stroke=\"currentColor\" stroke-width=\"4\" transform=\"rotate(30 50 50)\" />\n              <!-- Center glowing star representing Orion -->\n              <path d=\"M50 25L53.5 42.5L71 46L53.5 49.5L50 67L46.5 49.5L29 46L46.5 42.5Z\" fill=\"currentColor\" />\n            </svg>\n          </div>\n          <!-- Corporate Typography -->\n          <div class=\"flex flex-col\">\n            <span class=\"text-xl font-black tracking-tight text-white leading-none\">\n              오리온기전\n            </span>\n            <span class=\"text-[10px] font-bold uppercase tracking-widest text-slate-400 mt-1.5\">\n              ORION RELAY\n            </span>\n          </div>\n        </div>\n        <p class=\"text-sm text-slate-400 max-w-sm leading-relaxed\">\n          (주)오리온기전은 전자부품 및 제어기기 유통 전문 회사로써, 1974년 창업\n          이래 합리적인 가격, 우수한 품질, 신속한 납기를 대표 이념으로 삼아\n          최적의 제품을 공급하고 있습니다.\n        </p>\n      </div>\n\n      <!-- Quick Links -->\n      <div>\n        <h3\n          class=\"text-sm font-bold tracking-wider text-slate-200 uppercase mb-4\"\n        >\n          바로가기\n        </h3>\n        <ul class=\"space-y-3 text-sm\">\n          <li>\n            <NuxtLink\n              to=\"/company\"\n              class=\"hover:text-primary-400 transition-colors\"\n              >회사 소개</NuxtLink\n            >\n          </li>\n          <li>\n            <NuxtLink\n              to=\"/products\"\n              class=\"hover:text-primary-400 transition-colors\"\n              >제품 소개</NuxtLink\n            >\n          </li>\n          <li>\n            <NuxtLink\n              to=\"/inquiry\"\n              class=\"hover:text-primary-400 transition-colors\"\n              >온라인 문의</NuxtLink\n            >\n          </li>\n        </ul>\n      </div>\n\n      <!-- Contact Info -->\n      <div>\n        <h3\n          class=\"text-sm font-bold tracking-wider text-slate-200 uppercase mb-4\"\n        >\n          고객지원\n        </h3>\n        <ul class=\"space-y-3 text-sm text-slate-400\">\n          <li class=\"flex items-center gap-2\">\n            <Phone class=\"w-4 h-4 text-primary-500 shrink-0\" />\n            <span>02-6218-1402</span>\n          </li>\n          <li class=\"flex items-center gap-2\">\n            <Printer class=\"w-4 h-4 text-primary-500 shrink-0\" />\n            <span>02-6008-3254</span>\n          </li>\n          <li class=\"flex items-center gap-2\">\n            <Mail class=\"w-4 h-4 text-primary-500 shrink-0\" />\n            <span>orion@orionrelay.com</span>\n          </li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- Bottom Footer / Business Details -->\n    <div\n      class=\"border-t border-slate-800 bg-slate-950/60 py-8 text-xs text-slate-500 dark:text-slate-600\"\n    >\n      <div\n        class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6\"\n      >\n        <div class=\"space-y-2 leading-relaxed\">\n          <p>상호명: (주)오리온기전 | 사업자등록번호: 101-81-21364</p>\n          <p>\n            과천본사. 주소: 경기도 과천시 과천대로7길 33, 디테크타워 A동 504호 |\n            Tel:02-6218-1402 | Fax: 02-6008-3254 <br />\n            구로1매장, 주소: 서울특별시 구로구 구로동 1258번지 중앙유통단지 가동\n            3209호 | Tel: 02-6679-1403 | Faxc 02-6679-1404 <br />\n            구로2배장, 주소: 사울특별시 구로구 구로동 1258번지 중앙유통단지 마동\n            1116호 | Tel: 02-2265-1402 | Fa: 02-6008-3251\n          </p>\n          <p class=\"text-[10px]\">\n            &copy; {{ new Date().getFullYear() }} (주)오리온기전, (주)오리온FC.\n            All rights reserved.\n          </p>\n        </div>\n        <div class=\"flex items-center gap-4\">\n          <span\n            class=\"px-2.5 py-1 rounded bg-slate-800 text-slate-400 hover:text-slate-200 cursor-default\"\n            >품질제일주의</span\n          >\n          <span\n            class=\"px-2.5 py-1 rounded bg-slate-800 text-slate-400 hover:text-slate-200 cursor-default\"\n            >고객만족</span\n          >\n        </div>\n      </div>\n    </div>\n  </footer>\n</template>\n<script setup>\nimport { Cpu, Phone, Mail, Printer } from \"lucide-vue-next\";\n</script>\n","<template>\n  <div class=\"min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-300\">\n    <AppHeader />\n    <main class=\"flex-grow\">\n      <slot />\n    </main>\n    <AppFooter />\n  </div>\n</template>\n\n<script setup>\n// Shared layout logic if needed\n</script>\n"],"version":3}