{"file":"index-Cy6zpKOs.js","mappings":";;;;;;;;;;;;;;;;;;;;;AACO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,qBAAiB,MAAA,CAAA,CAAA,41BAAA;AAcN,YAAAC,mBAAAC,MAAA,QAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;;QAiBvB,IAAG;AAAA,QACH,OAAM;AAAA;yBAFR,CAKW,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAFV,eAED;AAAA;;;;;;QAEE,IAAG;AAAA,QACH,OAAM;AAAA;yBAFR,CAKW,GAAAD,QAAAC,UAAA,aAAA;;;;;8BAFV,cAED;AAAA;;;;;;AASO,YAAAH,mBAAAC,MAAA,GAAA,GAAA,EAAA,OAAM,6CAA4C,GAAA,MAAA,OAAA,CAAA;;AAKtC,YAAAD,mBAAAC,MAAA,WAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;AAUvB,YAAAD,mBAAAC,MAAA,GAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;AAsDrB,YAAAD,mBAAAC,MAAA,GAAA,GAAA,EAAA,OAAM,wBAAuB,GAAA,MAAA,OAAA,CAAA;;;QAM1B,IAAG;AAAA,QAAY,OAAM;AAAA;yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;AADU,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,aAAS,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BADoH,UAC/I;AAAA,cAAAC,YAA8BH,MAAA,UAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAO7B,YAAAD,mBAAAC,MAAA,GAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;;QAMZ,IAAG;AAAA,QAAY,OAAM;AAAA;yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;AADU,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,aAAS,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BADoH,UAC/I;AAAA,cAAAC,YAA8BH,MAAA,UAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAO1B,YAAAD,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;;QAMf,IAAG;AAAA,QAAY,OAAM;AAAA;yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;AADU,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,aAAS,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BADoH,UAC/I;AAAA,cAAAC,YAA8BH,MAAA,UAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAOtB,YAAAD,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;;QAMnB,IAAG;AAAA,QAAY,OAAM;AAAA;yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;AADU,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,aAAS,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BADoH,UAC/I;AAAA,cAAAC,YAA8BH,MAAA,UAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAOxB,YAAAD,mBAAAC,MAAA,QAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;;QAMjB,IAAG;AAAA,QAAY,OAAM;AAAA;yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;AADU,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,aAAS,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BADoH,UAC/I;AAAA,cAAAC,YAA8BH,MAAA,UAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAOzB,YAAAD,mBAAAC,MAAA,OAAA,GAAA,EAAA,OAAM,UAAS,GAAA,MAAA,OAAA,CAAA;;;QAMhB,IAAG;AAAA,QAAY,OAAM;AAAA;yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;AADU,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,aAAS,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BADoH,UAC/I;AAAA,cAAAC,YAA8BH,MAAA,UAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAiC3B,YAAAD,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,mDAAkD,GAAA,MAAA,OAAA,CAAA;;;QAsBjE,IAAG;AAAA,QACH,OAAM;AAAA;yBAFR,CAMW,GAAAC,QAAAC,UAAA,aAAA;;;AADG,YAAAD,OAAAF,mBAAAC,MAAA,UAAA,GAAA,EAAA,OAAM,4BAAwB,MAAAE,UAAA,QAAA,CAAA;AAAA;;8BAF3C,YAEC;AAAA,cAAAC,YAA6CH,MAAA,UAAA,GAAA,EAAjC,OAAM,yBAAwB,CAAA;AAAA;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_unref","_push","_parent","_createVNode"],"sources":["../../../../pages/index.vue"],"sourcesContent":["<template>\n  <div class=\"overflow-hidden\">\n    <!-- Hero Section -->\n    <section class=\"relative bg-gradient-to-br from-slate-900 via-slate-950 to-primary-950 text-white py-24 md:py-32 lg:py-40\">\n      <!-- Background Ambient Glows -->\n      <div class=\"absolute inset-0 overflow-hidden pointer-events-none opacity-40\">\n        <div class=\"absolute -top-40 -left-40 w-96 h-96 bg-primary-600 rounded-full blur-3xl\"></div>\n        <div class=\"absolute top-1/2 right-10 w-[500px] h-[500px] bg-sky-900 rounded-full blur-3xl\"></div>\n      </div>\n\n      <div class=\"relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          <!-- Text Content -->\n          <div class=\"space-y-8 lg:col-span-7\">\n            <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-500/10 border border-primary-500/20 text-primary-400 text-sm font-semibold\">\n              <Sparkles class=\"w-4 h-4\" />\n              <span>전자부품/제어기기 유통 및 솔루션 전문기업</span>\n            </div>\n            \n            <h1 class=\"text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight\">\n              합리적인 가격, 우수한 품질<br />\n              <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-sky-400\">\n                신속한 납기 약속\n              </span>\n            </h1>\n\n            <p class=\"text-lg text-slate-300 max-w-xl leading-relaxed\">\n              (주)오리온기전은 1974년 창업 이래 40여년간 글로벌 유수 제조사와 총판 및 대리점 계약을 통해 공정 자동화에 필요한 최적의 제품을 신속히 공급해 왔습니다.\n            </p>\n\n            <div class=\"flex flex-wrap gap-4\">\n              <NuxtLink \n                to=\"/products\" \n                class=\"px-8 py-4 text-base font-semibold text-white bg-primary-600 hover:bg-primary-500 rounded-xl transition-all shadow-lg shadow-primary-600/25 hover:scale-105\"\n              >\n                브랜드 카탈로그 보기\n              </NuxtLink>\n              <NuxtLink \n                to=\"/inquiry\" \n                class=\"px-8 py-4 text-base font-semibold text-slate-200 hover:text-white border border-slate-700 hover:border-slate-500 rounded-xl bg-white/5 backdrop-blur-sm transition-all hover:scale-105\"\n              >\n                견적 및 유통 문의\n              </NuxtLink>\n            </div>\n          </div>\n\n          <!-- Hero Graphic Card / Visual Asset -->\n          <div class=\"lg:col-span-5 relative\">\n            <div class=\"relative mx-auto max-w-md lg:max-w-none bg-slate-900/60 backdrop-blur-xl border border-slate-800 rounded-3xl p-8 shadow-2xl shadow-primary-500/5\">\n              <div class=\"flex justify-between items-start mb-8\">\n                <span class=\"text-xs font-bold text-primary-400 tracking-widest uppercase\">Orion Distributor Value</span>\n                <Cpu class=\"w-8 h-8 text-primary-500 animate-spin-slow\" />\n              </div>\n              <div class=\"space-y-6\">\n                <div class=\"p-4 bg-slate-950/40 rounded-2xl border border-slate-800/80 flex gap-4 items-center\">\n                  <div class=\"p-3 bg-primary-950/40 text-primary-400 rounded-xl\">\n                    <ShieldCheck class=\"w-6 h-6\" />\n                  </div>\n                  <div>\n                    <h3 class=\"font-bold text-slate-100\">원가 혁신 및 정품 보장</h3>\n                    <p class=\"text-xs text-slate-400\">글로벌 파트너사와 직접 계약을 통한 단가 절감</p>\n                  </div>\n                </div>\n                \n                <div class=\"p-4 bg-slate-950/40 rounded-2xl border border-slate-800/80 flex gap-4 items-center\">\n                  <div class=\"p-3 bg-sky-950/40 text-sky-400 rounded-xl\">\n                    <Zap class=\"w-6 h-6\" />\n                  </div>\n                  <div>\n                    <h3 class=\"font-bold text-slate-100\">풍부한 다량의 상시재고</h3>\n                    <p class=\"text-xs text-slate-400\">OMRON, OTAX 등 핵심 모델 재고 대량 즉시공급</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Stats Section -->\n    <section class=\"py-12 bg-slate-100 dark:bg-slate-900 transition-colors duration-300\">\n      <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 text-center\">\n          <div class=\"space-y-2\">\n            <p class=\"text-3xl sm:text-4xl font-extrabold text-primary-600 dark:text-primary-400\">1974</p>\n            <p class=\"text-sm font-semibold text-slate-500 dark:text-slate-400\">창립 연도</p>\n          </div>\n          <div class=\"space-y-2\">\n            <p class=\"text-3xl sm:text-4xl font-extrabold text-primary-600 dark:text-primary-400\">50+</p>\n            <p class=\"text-sm font-semibold text-slate-500 dark:text-slate-400\">국내외 공식 협력 파트너사</p>\n          </div>\n          <div class=\"space-y-2\">\n            <p class=\"text-3xl sm:text-4xl font-extrabold text-primary-600 dark:text-primary-400\">1,000+</p>\n            <p class=\"text-sm font-semibold text-slate-500 dark:text-slate-400\">상시 보유 재고 스펙 수</p>\n          </div>\n          <div class=\"space-y-2\">\n            <p class=\"text-3xl sm:text-4xl font-extrabold text-primary-600 dark:text-primary-400\">100%</p>\n            <p class=\"text-sm font-semibold text-slate-500 dark:text-slate-400\">정품 보장 및 안전 포장 배송</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Key Categories Section -->\n    <section class=\"py-20 md:py-28\">\n      <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div class=\"text-center space-y-4 mb-16\">\n          <h2 class=\"text-xs font-bold uppercase tracking-widest text-primary-600 dark:text-primary-400\">Products</h2>\n          <p class=\"text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white\">주요 제품 라인업</p>\n          <div class=\"h-1 w-12 bg-primary-600 mx-auto rounded-full\"></div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n          <!-- Card 1: 릴레이 (주력상품 강조) -->\n          <div class=\"group relative bg-gradient-to-br from-primary-50 to-white dark:from-primary-950/30 dark:to-slate-900 p-8 rounded-3xl border-2 border-primary-500/80 dark:border-primary-500/50 shadow-lg shadow-primary-500/5 hover:shadow-primary-500/10 hover:-translate-y-1 transition-all duration-300\">\n            <div class=\"absolute -top-3.5 right-6 px-3 py-1 bg-primary-600 text-white text-[10px] font-bold tracking-widest uppercase rounded-full shadow-md\">\n              주력 상품\n            </div>\n            <div class=\"p-3 bg-primary-600 text-white rounded-2xl w-fit mb-6 group-hover:scale-110 transition-transform shadow-lg shadow-primary-600/25\">\n              <Cpu class=\"w-6 h-6 animate-pulse\" />\n            </div>\n            <h3 class=\"text-xl font-bold text-slate-900 dark:text-white mb-3\">OMRON 릴레이 (Relays)</h3>\n            <p class=\"text-sm text-slate-600 dark:text-slate-300 leading-relaxed mb-6 font-medium\">\n              오리온기전 최고의 핵심 유통 품목인 OMRON MY형, LY형, G2R형 등 고신뢰성 제어용 파워 릴레이 재고를 대량 상시 보유하고 있습니다.\n            </p>\n            <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-1.5 text-sm font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-500\">\n              자세히 보기 <ArrowRight class=\"w-4 h-4\" />\n            </NuxtLink>\n          </div>\n\n          <!-- Card 2: SSR -->\n          <div class=\"group relative bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200/60 dark:border-slate-800/80 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300\">\n            <div class=\"p-3 bg-sky-50 dark:bg-sky-950/50 text-sky-600 dark:text-sky-400 rounded-2xl w-fit mb-6 group-hover:scale-110 transition-transform\">\n              <Zap class=\"w-6 h-6\" />\n            </div>\n            <h3 class=\"text-xl font-bold text-slate-900 dark:text-white mb-3\">반도체 릴레이 (SSR)</h3>\n            <p class=\"text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6\">\n              무접점 방식으로 물리적 노후화가 없는 OMRON G3NA 및 고속 스위칭 대응용 전력 제어 반도체 릴레이입니다.\n            </p>\n            <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-1.5 text-sm font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-500\">\n              자세히 보기 <ArrowRight class=\"w-4 h-4\" />\n            </NuxtLink>\n          </div>\n\n          <!-- Card 3: 소켓 -->\n          <div class=\"group relative bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200/60 dark:border-slate-800/80 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300\">\n            <div class=\"p-3 bg-amber-50 dark:bg-amber-950/50 text-amber-600 dark:text-amber-400 rounded-2xl w-fit mb-6 group-hover:scale-110 transition-transform\">\n              <Layers class=\"w-6 h-6\" />\n            </div>\n            <h3 class=\"text-xl font-bold text-slate-900 dark:text-white mb-3\">소켓 (Sockets)</h3>\n            <p class=\"text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6\">\n              릴레이 장착의 신뢰성을 극대화하는 OMRON PYF, PTF 고장력 DIN 레일 마운트식 단자대형 소켓 시리즈입니다.\n            </p>\n            <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-1.5 text-sm font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-500\">\n              자세히 보기 <ArrowRight class=\"w-4 h-4\" />\n            </NuxtLink>\n          </div>\n\n          <!-- Card 4: 스위치 -->\n          <div class=\"group relative bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200/60 dark:border-slate-800/80 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300\">\n            <div class=\"p-3 bg-rose-50 dark:bg-rose-950/50 text-rose-600 dark:text-rose-400 rounded-2xl w-fit mb-6 group-hover:scale-110 transition-transform\">\n              <ToggleLeft class=\"w-6 h-6\" />\n            </div>\n            <h3 class=\"text-xl font-bold text-slate-900 dark:text-white mb-3\">제어 스위치 (Switches)</h3>\n            <p class=\"text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6\">\n              DIP 스위치, 토글 스위치, 리미트 스위치 등 공정 기계 작동 및 전기 회로 세팅용 정밀 제어 스위치류입니다.\n            </p>\n            <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-1.5 text-sm font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-500\">\n              자세히 보기 <ArrowRight class=\"w-4 h-4\" />\n            </NuxtLink>\n          </div>\n\n          <!-- Card 5: 인터페이스 단자대 -->\n          <div class=\"group relative bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200/60 dark:border-slate-800/80 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300\">\n            <div class=\"p-3 bg-emerald-50 dark:bg-emerald-950/50 text-emerald-600 dark:text-emerald-400 rounded-2xl w-fit mb-6 group-hover:scale-110 transition-transform\">\n              <Workflow class=\"w-6 h-6\" />\n            </div>\n            <h3 class=\"text-xl font-bold text-slate-900 dark:text-white mb-3\">인터페이스 단자대</h3>\n            <p class=\"text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6\">\n              PLC 배선을 혁신적으로 단축하는 삼원ACT 고성능 분산형 콤팩트 링크 단자대 및 I/O 접속 케이블입니다.\n            </p>\n            <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-1.5 text-sm font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-500\">\n              자세히 보기 <ArrowRight class=\"w-4 h-4\" />\n            </NuxtLink>\n          </div>\n\n          <!-- Card 6: 콘트롤러 -->\n          <div class=\"group relative bg-white dark:bg-slate-900 p-8 rounded-3xl border border-slate-200/60 dark:border-slate-800/80 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300\">\n            <div class=\"p-3 bg-purple-50 dark:bg-purple-950/50 text-purple-600 dark:text-purple-400 rounded-2xl w-fit mb-6 group-hover:scale-110 transition-transform\">\n              <Sliders class=\"w-6 h-6\" />\n            </div>\n            <h3 class=\"text-xl font-bold text-slate-900 dark:text-white mb-3\">콘트롤러 (Controllers)</h3>\n            <p class=\"text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-6\">\n              INOVANCE 산업용 EtherCAT 모션 제어 PLC 및 OMRON 정밀 디바이스 디지털 온도조절기 제어 장치입니다.\n            </p>\n            <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-1.5 text-sm font-bold text-primary-600 dark:text-primary-400 group-hover:text-primary-500\">\n              자세히 보기 <ArrowRight class=\"w-4 h-4\" />\n            </NuxtLink>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Global & Local Network Section -->\n    <section class=\"py-20 bg-slate-900 text-white relative\">\n      <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-center\">\n          <div class=\"space-y-6\">\n            <h2 class=\"text-xs font-bold text-primary-400 uppercase tracking-widest\">Network</h2>\n            <p class=\"text-3xl sm:text-4xl font-extrabold\">글로벌 파트너쉽과 신속한 공급망</p>\n            <p class=\"text-slate-400 leading-relaxed\">\n              (주)오리온기전, (주)오리온FA, (주)오리온FC는 일본 OMRON, OTAX 등 세계 최고 수준의 브랜드 총판 및 공식 대리점으로서, 과천 본사와 구로 중앙유통단지 내 2개 전문 매장을 연계한 물류 거점을 통해 고객사가 원하는 최적의 제품을 필요한 시점에 맞추어 즉각 공급합니다.\n            </p>\n            <div class=\"pt-4 border-t border-slate-800 grid grid-cols-2 gap-6\">\n              <div>\n                <h4 class=\"font-bold text-slate-200\">50여 개국 국내외 유수 브랜드</h4>\n                <p class=\"text-xs text-slate-500\">OMRON, OTAX, INOVANCE, MEANWELL 등</p>\n              </div>\n              <div>\n                <h4 class=\"font-bold text-slate-200\">3개 거점 오프라인 채널</h4>\n                <p class=\"text-xs text-slate-500\">과천 본사 및 구로 유통단지 매장</p>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"relative bg-slate-950 border border-slate-800 rounded-3xl p-8 flex items-center justify-center min-h-[300px]\">\n            <!-- Elegant grid pattern as dynamic mockup graphic -->\n            <div class=\"absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary-950/40 via-slate-950 to-slate-950 opacity-90 rounded-3xl\"></div>\n            <div class=\"relative text-center space-y-4\">\n              <Globe class=\"w-16 h-16 text-primary-500 mx-auto animate-pulse\" />\n              <p class=\"font-bold text-slate-200\">온·오프라인을 통합하는 통합 제어 기기 유통망</p>\n              <p class=\"text-xs text-slate-500\">신속하고 정확한 납기로 공정 설계 R&D 업무를 지원합니다.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n\n    <!-- Final Call to Action -->\n    <section class=\"py-16 md:py-24 bg-gradient-to-r from-primary-700 to-sky-700 text-white text-center relative overflow-hidden\">\n      <div class=\"absolute inset-0 bg-slate-950/20 backdrop-blur-[1px]\"></div>\n      <div class=\"relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8\">\n        <h2 class=\"text-3xl sm:text-4xl font-extrabold tracking-tight\">\n          오리온기전과 함께 더 견고한 전력 시스템을 설계해보세요\n        </h2>\n        <p class=\"text-slate-100 max-w-xl mx-auto text-sm sm:text-base opacity-90 leading-relaxed\">\n          필요하신 스펙의 도면이나 제품 사양서를 첨부하여 견적 요청을 해주시면, 담당 엔지니어가 실시간으로 상담해 드립니다.\n        </p>\n        <div>\n          <NuxtLink \n            to=\"/inquiry\" \n            class=\"inline-flex items-center gap-2 px-8 py-4 text-base font-semibold text-slate-900 bg-white hover:bg-slate-100 rounded-xl transition-all shadow-xl shadow-slate-900/10 hover:scale-105\"\n          >\n            온라인 문의하기\n            <ArrowRight class=\"w-5 h-5 text-slate-900\" />\n          </NuxtLink>\n        </div>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script setup>\nimport { Sparkles, Cpu, ShieldCheck, Zap, Layers, Globe, ArrowRight, ToggleLeft, Workflow, Sliders } from 'lucide-vue-next'\n\n</script>\n\n<style scoped>\n.animate-spin-slow {\n  animation: spin 15s linear infinite;\n}\n\n@keyframes spin {\n  from {\n    transform: rotate(0deg);\n  }\n  to {\n    transform: rotate(360deg);\n  }\n}\n</style>\n"],"version":3}